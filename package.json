{
  "name": "adocserver",
  "version": "0.1.15",
  "description": "Zero-config AsciiDoc dev server with sidebar navigation and live reload; suitable for preparing documentation to control LLM Agents",
  "type": "module",
  "bin": {
    "adocserver": "bin/adocserver.js"
  },
  "files": [
    "bin",
    "src",
    "assets"
  ],
  "scripts": {
    "start": "node bin/adocserver.js",
    "test:unit": "node --test 'tests/unit/*.test.js'",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "asciidoctor": "^3.0.4",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "asciidoc",
    "docs",
    "documentation",
    "vite",
    "dev-server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dims12/adocserver"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
